# Note: src/config.js is intentionally NOT gitignored.
# Its only "secret" is the Azure OAuth client ID, which per the OAuth 2.0 SPA
# spec is a public identifier — security comes from the registered redirect URI
# list in Azure, not from hiding the client ID. The PWA needs config.js at
# runtime, so it must be served from GitHub Pages.

# Editor / OS
.DS_Store
Thumbs.db
.vscode/
.idea/

# Dependencies (none expected — this is a build-step-free static site,
# but ignore in case future tooling adds them)
node_modules/
package-lock.json
.cache/

# Local data — never commit any boards data, ever.
*.boards.json
boards.json
boards.backup.*.json

# Local source-file backups (per project rules, kept locally before edits).
# No reason to ship them through GitHub Pages.
backups/
